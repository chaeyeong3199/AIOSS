{
  "name": "@chaeyeong3199/aioss",
  "version": "1.0.1",
  "description": "AIOSS week 9 package for GitHub Packages and Docker automation",
  "main": "src/index.js",
  "bin": {
    "aioss": "bin/aioss.js"
  },
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test",
    "test:coverage": "c8 --check-coverage --lines 80 --branches 80 --functions 80 --statements 80 --include src/**/*.js --exclude src/server.js node --test",
    "test:e2e": "playwright test",
    "audit:ci": "npm audit --audit-level=moderate",
    "experiment:l13": "node scripts/generate-week13-data.js",
    "report:l13": "node scripts/summarize-week13-metrics.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chaeyeong3199/AIOSS.git"
  },
  "keywords": [
    "aioss",
    "github-packages",
    "docker",
    "dependabot"
  ],
  "author": "chaeyeong3199",
  "license": "MIT",
  "dependencies": {
    "express": "^5.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "c8": "^11.0.0"
  }
}
